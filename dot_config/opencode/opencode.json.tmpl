{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "mcp-github-public": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{{ onepasswordRead "op://Employee/OpenCode Config/github_public_token" }}"
      },
      "enabled": true
    },
    "mcp-github-samsung": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "-e",
        "GITHUB_HOST",
        "ghcr.io/github/github-mcp-server"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{{ onepasswordRead "op://Employee/OpenCode Config/github_samsung_token" }}",
        "GITHUB_HOST": "https://github.ecodesamsung.com"
      },
      "enabled": true
    },
    "mcp-atlassian": {
      "type": "local",
      "command": [
        "uvx",
        "--python=3.12",
        "mcp-atlassian"
      ],
      "environment": {
        "CONFLUENCE_URL": "https://smartthings.atlassian.net/wiki",
        "CONFLUENCE_USERNAME": "{{ onepasswordRead "op://Employee/OpenCode Config/atlassian_username" }}",
        "CONFLUENCE_API_TOKEN": "{{ onepasswordRead "op://Employee/OpenCode Config/atlassian_api_token" }}",
        "JIRA_URL": "https://smartthings.atlassian.net",
        "JIRA_USERNAME": "{{ onepasswordRead "op://Employee/OpenCode Config/atlassian_username" }}",
        "JIRA_API_TOKEN": "{{ onepasswordRead "op://Employee/OpenCode Config/atlassian_api_token" }}"
      },
      "enabled": true
    },
    "mcp-atlassian-remote": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    },
    "mcp-agent-mail": {
      "type": "remote",
      "url": "http://127.0.0.1:8765/api/",
      "headers": {
        "Authorization": "Bearer 5e1c8a8a72e68235f6da785c117d6df583c23e790228781cbc9504f67ce581c1"
      },
      "enabled": true
    }
  }
}
