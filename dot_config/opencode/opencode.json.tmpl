{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [],
  "default_agent": "plan",
  "formatter": {
    "rustfmt": {
      "disabled": true
    },
    "cargofmt": {
      "command": ["cargo", "fmt", "--"],
      "extensions": [".rs"]
    }
  },
  "permission": {
    "bash": {
      "git add *": "deny",
      "git commit *": "deny",
      "git push *": "deny",
      "sudo *": "deny"
    }
  },
  "mcp": {
    "mcp-atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    }
  },
  "tools": {
    "mcp-*": false
  },
  "agent": {
    "general": { "model": "github-copilot/gpt-5-mini" },
    "explore": { "model": "github-copilot/gpt-5-mini" },
    "title": { "model": "github-copilot/gpt-5-mini" },
    "summary": { "model": "github-copilot/gpt-5-mini" },
    "explore-atlassian": {
      "description": "Fast agent specialized for querying Confluence and Jira. Use this when asked to search Confluence documents or Jira issues.",
      "mode": "subagent",
      "model": "github-copilot/gpt-5-mini",
      "prompt": "{file:./prompts/explore-atlassian.txt}",
      "tools": {
        "*": false,
        "mcp-atlassian_*": true
      }
    },
    "explore-github": {
      "description": "Fast agent specialized for querying GitHub. Use this when asked to inspect repos or pull requests.",
      "mode": "subagent",
      "model": "github-copilot/gpt-5-mini",
      "prompt": "{file:./prompts/explore-github.txt}",
      "permission": {
        "bash": {
          "*": "deny",
          "gh *": "allow"
        }
      }
    }
  }
}
